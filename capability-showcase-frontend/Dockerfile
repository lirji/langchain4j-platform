# 独立前端：多阶段构建（node 构建 → nginx 静态托管）。前后端分离，不依赖任何后端服务。
# 网关地址在构建期烘焙：docker build --build-arg VITE_EDGE_BASE_URL=https://api.example.com
FROM node:20-alpine AS build
ARG VITE_EDGE_BASE_URL=
ARG VITE_BASE=/
ARG VITE_AUTH_BASE_URL=
ARG VITE_REQUIRE_LOGIN=true
# RBAC 控制台三个 kill switch：默认开（只可强制关闭）。真正可用仍受 role-admin scope / 运行时配置约束。
ARG VITE_RBAC_CONSOLE_ENABLED=true
ARG VITE_SHARED_KB_UI_ENABLED=true
# 生产默认关闭 demo 一键登录，且不注入口令 —— 保证产物不含任何明文口令。
ARG VITE_DEMO_LOGIN_ENABLED=false
ARG VITE_DEMO_PASSWORD=
# ③ 阶段④ Casdoor OIDC（构建期烘焙、可秒回滚）：默认 apikey（引入即安全）。client_id 须 = edge.casdoor.audiences。
ARG VITE_AUTH_MODE=apikey
ARG VITE_CASDOOR_ISSUER=http://localhost:8000
ARG VITE_CASDOOR_CLIENT_ID=cad5642b16071c3513d4
ARG VITE_CASDOOR_SCOPES=openid profile email offline_access
ARG VITE_CASDOOR_REDIRECT_PATH=callback
ARG VITE_CASDOOR_POST_LOGOUT_PATH=login
ARG VITE_CASDOOR_SILENT_PATH=oidc-silent
ENV VITE_EDGE_BASE_URL=$VITE_EDGE_BASE_URL
ENV VITE_BASE=$VITE_BASE
ENV VITE_AUTH_BASE_URL=$VITE_AUTH_BASE_URL
ENV VITE_REQUIRE_LOGIN=$VITE_REQUIRE_LOGIN
ENV VITE_RBAC_CONSOLE_ENABLED=$VITE_RBAC_CONSOLE_ENABLED
ENV VITE_SHARED_KB_UI_ENABLED=$VITE_SHARED_KB_UI_ENABLED
ENV VITE_DEMO_LOGIN_ENABLED=$VITE_DEMO_LOGIN_ENABLED
ENV VITE_DEMO_PASSWORD=$VITE_DEMO_PASSWORD
ENV VITE_AUTH_MODE=$VITE_AUTH_MODE
ENV VITE_CASDOOR_ISSUER=$VITE_CASDOOR_ISSUER
ENV VITE_CASDOOR_CLIENT_ID=$VITE_CASDOOR_CLIENT_ID
ENV VITE_CASDOOR_SCOPES=$VITE_CASDOOR_SCOPES
ENV VITE_CASDOOR_REDIRECT_PATH=$VITE_CASDOOR_REDIRECT_PATH
ENV VITE_CASDOOR_POST_LOGOUT_PATH=$VITE_CASDOOR_POST_LOGOUT_PATH
ENV VITE_CASDOOR_SILENT_PATH=$VITE_CASDOOR_SILENT_PATH
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
