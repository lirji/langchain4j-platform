# 复制为 .env 或在构建期以环境变量注入。

# 业务能力经边缘网关的基址。
#   - 本地 dev：留空（走 vite 代理到 :8080，同源无跨域）。
#   - 分离部署：设为网关地址，如 https://api.example.com（需网关 CORS 放行本前端来源）。
VITE_EDGE_BASE_URL=

# SPA 部署子路径，默认根 /。若部署在子路径（如 https://host/showcase/）设为 /showcase/。
VITE_BASE=/

# 能力目录来源。默认使用打包进前端的静态 catalog.json（由 capabilities.yml 生成，零后端依赖）。
# 如需后端动态目录，取消注释并指向接口：
# VITE_CATALOG_URL=https://api.example.com/showcase/api/catalog

# 是否启用 live discovery（默认启用）。
# VITE_LIVE_DISCOVERY=true

# 登录端点 /auth/* 基址。默认留空 → 相对路径，走 vite 同源代理（dev）/ nginx 同源反代（prod），
# 使刷新令牌 httpOnly cookie 为第一方 SameSite=Lax，最省心。跨域场景设为网关地址并要求后端下发
# SameSite=None;Secure（HTTPS）+ 网关 allowCredentials。
# VITE_AUTH_BASE_URL=

# 是否强制登录（路由守卫）。默认 true；置 false 退回"纯手输 API Key"老流程（回滚开关）。
# VITE_REQUIRE_LOGIN=true

# ── RBAC 控制台三个 kill switch（默认开；只可强制关闭。管理域是否真正可用仍由 role-admin scope 决定）──
# RBAC 管理控制台入口（用户/角色管理）。置 false 前端彻底隐藏 /admin 与相关入口（灰度/回滚）。
# VITE_RBAC_CONSOLE_ENABLED=true
# 共享知识库 UI（RAG 双视图）。置 false 只展示租户库；真正可用仍取决于服务端 /rag/config.publicEnabled。
# VITE_SHARED_KB_UI_ENABLED=true
# 演示账号一键登录卡。生产置 false（登录页不渲染 demo 卡）。
# VITE_DEMO_LOGIN_ENABLED=true

# demo 一键登录口令：仅供内部/本地演示注入（如 demo12345），使 demo 卡可一键提交。
# **绝不在生产构建设置**——为空时 demo 卡仅预填用户名、需手动输入密码，且产物不含任何明文口令。
# VITE_DEMO_PASSWORD=
