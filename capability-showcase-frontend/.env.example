# 复制为 .env 或在构建期以环境变量注入。

# 业务能力经边缘网关的基址。
#   - 本地 dev：留空（走 vite 代理到 :8080，同源无跨域）。
#   - 分离部署：设为网关地址，如 https://api.example.com（需网关 CORS 放行本前端来源）。
VITE_EDGE_BASE_URL=

# SPA 部署子路径，默认根 /。若部署在子路径（如 https://host/showcase/）设为 /showcase/。
VITE_BASE=/

# 能力目录来源。默认使用打包进前端的静态 catalog.json（由 capabilities.yml 生成，零后端依赖）。
# 如需后端动态目录，取消注释并指向接口：
# VITE_CATALOG_URL=https://api.example.com/showcase/api/catalog

# 是否启用 live discovery（默认启用）。
# VITE_LIVE_DISCOVERY=true

# 登录端点 /auth/* 基址。默认留空 → 相对路径，走 vite 同源代理（dev）/ nginx 同源反代（prod），
# 使刷新令牌 httpOnly cookie 为第一方 SameSite=Lax，最省心。跨域场景设为网关地址并要求后端下发
# SameSite=None;Secure（HTTPS）+ 网关 allowCredentials。
# VITE_AUTH_BASE_URL=

# 是否强制登录（路由守卫）。默认 true；置 false 退回"纯手输 API Key"老流程（回滚开关）。
# VITE_REQUIRE_LOGIN=true

# ── kill switch（默认开；只可强制关闭）──
# 共享知识库 UI（RAG 双视图）。置 false 只展示租户库；真正可用仍取决于服务端 /rag/config.publicEnabled。
# VITE_SHARED_KB_UI_ENABLED=true
# 演示账号一键登录卡。生产置 false（登录页不渲染 demo 卡）。
# VITE_DEMO_LOGIN_ENABLED=true

# demo 一键登录口令：仅供内部/本地演示注入（如 demo12345），使 demo 卡可一键提交。
# **绝不在生产构建设置**——为空时 demo 卡仅预填用户名、需手动输入密码，且产物不含任何明文口令。
# VITE_DEMO_PASSWORD=

# ── Casdoor OIDC（阶段④，默认关；引入即安全）────────────────────────────────────
# 认证模式（构建期灰度/回滚开关）：apikey（默认，现状）| oidc（Casdoor 登录）| dual（迁移期两者都带）。
# 顺序约束：先开后端 edge 的 EDGE_CASDOOR_ENABLED=true，再把前端切 oidc，否则 Casdoor Bearer 被网关 401。
# VITE_AUTH_MODE=apikey
# Casdoor issuer（oidc-client-ts authority，自动 discovery）。dev 本地 docker 默认 http://localhost:8000。
# VITE_CASDOOR_ISSUER=http://localhost:8000
# Casdoor Shared Application 的 base client_id（方案C 多租户；每租户实际以 <base>-org-<tenant> 登录）。
# 须与 edge edge.casdoor.audiences 的 base 一致（边缘按 <base>-org-* audience 家族 + (owner,aud) 绑定放行，非逐字相等）。
# VITE_CASDOOR_CLIENT_ID=ragshared0client00000001
# OIDC 请求 scope（业务 scope 由 Casdoor permissions claim 展开，不在此请求）。
# VITE_CASDOOR_SCOPES=openid profile email offline_access
# SPA 内回调/登出/静默续期路径（相对 BASE_URL，无前导斜杠）；三者须在 Casdoor app redirectUris 精确登记。
# 注：silent 路径刻意不带扩展名，使 vite/nginx 的 SPA fallback 能兜到 index.html（main.ts 短路处理静默回调）。
# VITE_CASDOOR_REDIRECT_PATH=callback
# VITE_CASDOOR_POST_LOGOUT_PATH=login
# VITE_CASDOOR_SILENT_PATH=oidc-silent
